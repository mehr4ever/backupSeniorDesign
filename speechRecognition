import rospy
from std_msgs.msg import String
from duckietown_msgs.msg import Twist2DStamped

class VoiceListener:
    def __init__(self):
        self.node_name = rospy.get_name()
        # Publisher to the wheels
        self.pub_wheels = rospy.Publisher("~wheels_driver_node/car_cmd", Twist2DStamped, queue_size=1)
        
        # Subscriber to your laptop's voice commands
        self.sub_voice = rospy.Subscriber("/duckiebot_name/voice_commands", String, self.callback)

    def callback(self, msg):
        command = msg.data
        move_msg = Twist2DStamped()
        
        if "forward" in command:
            move_msg.v = 0.4  # Speed
            move_msg.omega = 0.0
        elif "left" in command:
            move_msg.v = 0.2
            move_msg.omega = 1.0 # Turning rate
        elif "stop" in command:
            move_msg.v = 0.0
            move_msg.omega = 0.0
            
        self.pub_wheels.publish(move_msg)
        rospy.loginfo(f"Executing: {command}")

if __name__ == '__main__':
    rospy.init_node('voice_listener', anonymous=True)
    listener = VoiceListener()
    rospy.spin()
